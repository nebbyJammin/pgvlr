# DB Configuration

POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb
POSTGRES_PORT=5432
POSTGRES_VOLUME=myvolume
POSTGRES_HOST=localhost

PRIVATE_API_PORT=8111

# Private API Configuration

PRIVATE_API_DB_HOST=db # The name of the container running postgres
PRIVATE_API_DB_PORT=5432 # The port number of the postgres instance